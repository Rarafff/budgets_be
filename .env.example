APP_ENV=development
OPENROUTER_API_KEY=replace-with-your-openrouter-key
OPENROUTER_PRIMARY_MODEL=openai/gpt-oss-120b:free
OPENROUTER_FALLBACK_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
OPENROUTER_CHEAP_MODEL=openai/gpt-oss-20b:free
OPENROUTER_RECEIPT_MODEL=nvidia/nemotron-nano-12b-v2-vl:free
DATABASE_URL=postgresql://postgres:replace-with-your-password@db.your-project-ref.supabase.co:5432/postgres
JWT_SECRET=replace-with-a-long-random-secret
PORT=8080
ALLOWED_ORIGINS=http://localhost:5173
MAX_REQUEST_BODY_BYTES=10485760
